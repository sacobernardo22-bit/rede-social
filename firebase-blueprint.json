{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "coverURL": { "type": "string" },
        "bio": { "type": "string" },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video", "none"] },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "content", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderUid", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "A temporary story post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "mediaUrl", "createdAt", "expiresAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "recipientUid": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message"] },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["recipientUid", "senderUid", "type", "createdAt"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "posts": { "schema": "Post", "description": "Public posts" },
    "messages": { "schema": "Message", "description": "Chat messages" },
    "stories": { "schema": "Story", "description": "Temporary stories" },
    "notifications": { "schema": "Notification", "description": "User notifications" }
  }
}
